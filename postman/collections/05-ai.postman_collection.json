  "item": [
    {
      "name": "Check symptoms",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Ho khan, sot cao va dau dau trong hai ngay\"\n}"
        },
        "url": {
          "raw": "{{ai_base_url}}/api/v1/ai/check",
          "host": [
            "{{ai_base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "ai",
            "check"
          ]
        }
      }
    },
    {
