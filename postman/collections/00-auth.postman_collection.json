          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrlAuth}}/api/v1/auth/login",
          "host": [
            "{{baseUrlAuth}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "Login with the seeded doctor account and assert doctor RBAC mapping."
      },
      "response": []
    },
