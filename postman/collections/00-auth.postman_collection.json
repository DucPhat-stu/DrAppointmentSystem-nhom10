{
  "info": {
    "_postman_id": "4e2c71aa-13d8-4f9a-9e0d-6ea6f41b9c50",
    "name": "00-auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Core auth flow for local MVP: register PATIENT, login, refresh, logout. OTP/2FA flows are intentionally excluded."
  },
  "item": [
    {
      "name": "Register Patient",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Register success envelope', function () {",
              "    pm.expect(body.success).to.eql(true);",
              "    pm.expect(body.data.role).to.eql('PATIENT');",
              "});",
              "pm.environment.set('registeredPatientEmail', body.data.email);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{registerName}}\",\n  \"email\": \"{{registerEmail}}\",\n  \"phone\": \"{{registerPhone}}\",\n  \"password\": \"{{registerPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrlAuth}}/auth/register",
          "host": [
            "{{baseUrlAuth}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Self-register a patient account. The MVP contract does not accept role switching at registration."
      },
      "response": []
    },
    {
