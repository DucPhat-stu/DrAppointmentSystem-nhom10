{
  "info": {
    "_postman_id": "d2e3f4a5-b6c7-4d8e-9f0a-1b2c3d4e5f6a",
    "name": "02-doctor",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Doctor service: list doctors, doctor detail, available slots, schedules, time slots, and doctor appointment actions."
  },
  "item": [
    {
      "name": "List Doctors",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors?date={{appointmentDate}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Doctor list returned', function () { pm.expect(body.data).to.be.an('array'); });",
              "if (body.data && body.data.length > 0) {",
              "  pm.environment.set('doctorId', body.data[0].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Doctor Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/{{doctorId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Doctor detail has name', function () { pm.expect(body.data.name || body.data.fullName).to.be.a('string'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Available Slots",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/{{doctorId}}/available-slots?date={{appointmentDate}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Slots is array', function () { pm.expect(body.data).to.be.an('array'); });",
              "if (body.data && body.data.length > 0) {",
              "  pm.environment.set('slotId', body.data[0].id);",
              "  if (body.data.length > 1) pm.environment.set('alternateSlotId', body.data[1].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — List Schedules",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/schedules"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Schedules returned', function () { pm.expect(body.success).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — List Appointments",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments?page=0&size=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Doctor appointments loaded', function () { pm.expect(body.success).to.eql(true); });",
              "if (body.data && body.data.content && body.data.content.length > 0) {",
              "  pm.environment.set('appointmentId', body.data.content[0].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — Get Appointment Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Appointment detail loaded', function () { pm.expect(body.data.id).to.eql(pm.environment.get('appointmentId')); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — Confirm Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-doc-confirm" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/confirm"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Confirmed', function () { pm.expect(body.data.status).to.eql('CONFIRMED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — Reject Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-doc-reject" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Postman reject test\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/reject"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or conflict', function () { pm.expect([200, 409]).to.include(pm.response.code); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — Complete Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-doc-complete" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/complete"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or guarded', function () { pm.expect([200, 409]).to.include(pm.response.code); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor — Cancel Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-doc-cancel" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Postman cancel test\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/cancel"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or conflict', function () { pm.expect([200, 409]).to.include(pm.response.code); });"
            ]
          }
        }
      ]
    }
  ]
}
