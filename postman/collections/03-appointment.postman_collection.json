{
  "info": {
    "_postman_id": "0f554741-842e-45b7-a5f7-58c51f5cc103",
    "name": "03-appointment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Appointment regression coverage for list, detail, cancel, reschedule, doctor confirm and complete guard."
  },
  "item": [
    {
      "name": "Patient List Appointments",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" }
        ],
        "url": "{{baseUrlAppointment}}/api/v1/appointments?page=0&size=20"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('List success envelope', function () { pm.expect(body.success).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Patient Get Appointment Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" }
        ],
        "url": "{{baseUrlAppointment}}/api/v1/appointments/{{appointmentId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Detail has appointment id', function () { pm.expect(body.data.id).to.eql(pm.environment.get('appointmentId')); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Patient Reschedule Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-reschedule" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"slotId\": \"{{alternateSlotId}}\",\n  \"reason\": \"Postman reschedule smoke\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrlAppointment}}/api/v1/appointments/{{appointmentId}}/reschedule"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or conflict if slot raced', function () { pm.expect([200, 409]).to.include(pm.response.code); });",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Reschedule sets appointment pending', function () { pm.expect(body.data.status).to.eql('PENDING'); });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Patient Cancel Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenPatient}}" },
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-cancel" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Postman cancellation smoke\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrlAppointment}}/api/v1/appointments/{{appointmentId}}/cancel"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Cancel sets cancelled', function () { pm.expect(body.data.status).to.eql('CANCELLED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor Confirm Appointment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-confirm" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/confirm"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Confirm sets confirmed', function () { pm.expect(body.data.status).to.eql('CONFIRMED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Doctor Complete Future Appointment Guard",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessTokenDoctor}}" },
          { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}-complete" }
        ],
        "url": "{{baseUrlDoctor}}/api/v1/doctors/appointments/{{appointmentId}}/complete"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Future appointment complete is guarded', function () { pm.expect([200, 409]).to.include(pm.response.code); });",
              "if (pm.response.code === 409) {",
              "  const body = pm.response.json();",
              "  pm.test('Conflict envelope returned', function () { pm.expect(body.success).to.eql(false); });",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
